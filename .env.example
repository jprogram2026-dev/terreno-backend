# Copie para .env e ajuste para seu ambiente local

# CORS — domínios permitidos pelo frontend, separados por vírgula
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:5500

# TTL do cache em segundos (padrão: 6 horas)
CACHE_TTL_SECONDS=21600

# Tamanho máximo do cache em memória (chaves)
CACHE_MAX_SIZE=1024

# Google Trends — proxy de saída opcional para evitar bloqueio
# (formato: http://usuario:senha@host:porta ou deixe vazio)
PYTRENDS_PROXY=

# Logging
LOG_LEVEL=INFO

# RAIS via BigQuery (opcional)
# Para ativar, configure UMA das opções abaixo:
#
# Opção 1 — Service Account (recomendado para deploy):
#   GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json
#
# Opção 2 — Application Default Credentials (uso local):
#   gcloud auth application-default login
#   Depois defina apenas o projeto:
GCP_PROJECT_ID=

# Se ambos forem vazios, RAIS fica desativada e o relatório segue sem ela.
